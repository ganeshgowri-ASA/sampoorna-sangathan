<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="onboarding_stage_pending" model="hr.onboarding.stage">
            <field name="name">Pending</field>
            <field name="sequence">10</field>
        </record>
        <record id="onboarding_stage_in_progress" model="hr.onboarding.stage">
            <field name="name">In Progress</field>
            <field name="sequence">20</field>
        </record>
        <record id="onboarding_stage_review" model="hr.onboarding.stage">
            <field name="name">Under Review</field>
            <field name="sequence">30</field>
        </record>
        <record id="onboarding_stage_done" model="hr.onboarding.stage">
            <field name="name">Completed</field>
            <field name="sequence">40</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>
