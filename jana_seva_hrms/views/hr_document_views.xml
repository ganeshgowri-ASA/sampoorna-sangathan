<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Document Type List -->
    <record id="hr_document_type_tree" model="ir.ui.view">
        <field name="name">hr.document.type.list</field>
        <field name="model">hr.document.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="has_expiry"/>
                <field name="required_for_onboarding"/>
                <field name="days_before_expiry_alert"/>
            </tree>
        </field>
    </record>

    <record id="action_hr_document_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">hr.document.type</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- Document List -->
    <record id="hr_document_tree" model="ir.ui.view">
        <field name="name">hr.document.list</field>
        <field name="model">hr.document</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_expired"
                  decoration-warning="is_expiring_soon">
                <field name="is_expired" column_invisible="1"/>
                <field name="is_expiring_soon" column_invisible="1"/>
                <field name="name"/>
                <field name="employee_id" widget="many2one_avatar"/>
                <field name="document_type_id"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'verified'"
                       decoration-info="state == 'submitted'"
                       decoration-danger="state in ('expired', 'rejected')"/>
            </tree>
        </field>
    </record>

    <!-- Document Form -->
    <record id="hr_document_form" model="ir.ui.view">
        <field name="name">hr.document.form</field>
        <field name="model">hr.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_verify" string="Verify"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected', 'expired')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,verified"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Document Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="document_type_id"/>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                        </group>
                        <group>
                            <field name="verified_by_id" invisible="state != 'verified'"/>
                            <field name="verified_date" invisible="state != 'verified'"/>
                            <field name="is_expiring_soon" invisible="1"/>
                            <field name="is_expired" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                            <field name="rejection_reason"
                                   invisible="state != 'rejected'"
                                   placeholder="Reason for rejection..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Document Search -->
    <record id="hr_document_search" model="ir.ui.view">
        <field name="name">hr.document.search</field>
        <field name="model">hr.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <filter name="expiring_soon" string="Expiring Soon"
                        domain="[('is_expiring_soon', '=', True)]"/>
                <filter name="expired" string="Expired"
                        domain="[('is_expired', '=', True)]"/>
                <separator/>
                <filter name="verified" string="Verified"
                        domain="[('state', '=', 'verified')]"/>
                <filter name="pending" string="Pending Verification"
                        domain="[('state', '=', 'submitted')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_type" string="Document Type"
                            context="{'group_by': 'document_type_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">hr.document</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="hr_document_search"/>
    </record>

    <!-- Employee Form - Documents Tab -->
    <record id="hr_employee_document_form" model="ir.ui.view">
        <field name="name">hr.employee.document.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Documents">
                    <field name="document_ids">
                        <tree>
                            <field name="name"/>
                            <field name="document_type_id"/>
                            <field name="expiry_date"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'verified'"
                                   decoration-danger="state in ('expired', 'rejected')"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
