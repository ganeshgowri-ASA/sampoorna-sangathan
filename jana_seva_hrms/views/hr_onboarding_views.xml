<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Onboarding Task Kanban -->
    <record id="hr_onboarding_task_kanban" model="ir.ui.view">
        <field name="name">hr.onboarding.task.kanban</field>
        <field name="model">hr.onboarding.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id">
                <field name="stage_id"/>
                <field name="employee_id"/>
                <field name="assigned_to_id"/>
                <field name="date_deadline"/>
                <field name="is_done"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click #{record.is_done.raw_value ? 'oe_kanban_card_ribbon' : ''}">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_body">
                                    <field name="employee_id" widget="many2one_avatar"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="date_deadline" widget="remaining_days"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="assigned_to_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Onboarding Task List -->
    <record id="hr_onboarding_task_tree" model="ir.ui.view">
        <field name="name">hr.onboarding.task.list</field>
        <field name="model">hr.onboarding.task</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="employee_id" widget="many2one_avatar"/>
                <field name="stage_id"/>
                <field name="assigned_to_id" widget="many2one_avatar_user"/>
                <field name="date_deadline"/>
                <field name="is_done"/>
            </tree>
        </field>
    </record>

    <!-- Onboarding Task Form -->
    <record id="hr_onboarding_task_form" model="ir.ui.view">
        <field name="name">hr.onboarding.task.form</field>
        <field name="model">hr.onboarding.task</field>
        <field name="arch" type="xml">
            <form>
                <field name="is_done" invisible="1"/>
                <header>
                    <button name="action_mark_done" string="Mark Done"
                            type="object" class="btn-primary"
                            invisible="is_done"/>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="assigned_to_id"/>
                        </group>
                        <group>
                            <field name="date_deadline"/>
                            <field name="date_done"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Onboarding Task Action -->
    <record id="action_hr_onboarding_task" model="ir.actions.act_window">
        <field name="name">Onboarding Tasks</field>
        <field name="res_model">hr.onboarding.task</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- Employee Form - Onboarding Tab -->
    <record id="hr_employee_onboarding_form" model="ir.ui.view">
        <field name="name">hr.employee.onboarding.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Onboarding">
                    <group>
                        <group>
                            <field name="onboarding_state" widget="badge"
                                   decoration-success="onboarding_state == 'done'"
                                   decoration-info="onboarding_state == 'in_progress'"
                                   decoration-warning="onboarding_state == 'not_started'"/>
                        </group>
                        <group>
                            <field name="onboarding_progress" widget="progressbar"/>
                        </group>
                    </group>
                    <field name="onboarding_task_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="stage_id"/>
                            <field name="assigned_to_id" widget="many2one_avatar_user"/>
                            <field name="date_deadline"/>
                            <field name="is_done"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
