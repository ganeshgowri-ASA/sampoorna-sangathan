<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="document_category_hr" model="lekha.document.category">
        <field name="name">Human Resources</field>
        <field name="code">HR</field>
        <field name="sequence">10</field>
    </record>
    <record id="document_category_finance" model="lekha.document.category">
        <field name="name">Finance</field>
        <field name="code">FIN</field>
        <field name="sequence">20</field>
    </record>
    <record id="document_category_legal" model="lekha.document.category">
        <field name="name">Legal</field>
        <field name="code">LEG</field>
        <field name="sequence">30</field>
    </record>
    <record id="document_category_operations" model="lekha.document.category">
        <field name="name">Operations</field>
        <field name="code">OPS</field>
        <field name="sequence">40</field>
    </record>
    <record id="document_category_general" model="lekha.document.category">
        <field name="name">General</field>
        <field name="code">GEN</field>
        <field name="sequence">50</field>
    </record>

    <!-- Default Document Templates -->
    <record id="template_sop_basic" model="lekha.document.template">
        <field name="name">Standard Operating Procedure</field>
        <field name="document_type">procedure</field>
        <field name="category_id" ref="document_category_operations"/>
        <field name="sequence">10</field>
        <field name="description">Use this template for documenting standard operating procedures.</field>
        <field name="content">&lt;h2&gt;Purpose&lt;/h2&gt;
&lt;p&gt;Describe the purpose of this procedure.&lt;/p&gt;
&lt;h2&gt;Scope&lt;/h2&gt;
&lt;p&gt;Define who this procedure applies to.&lt;/p&gt;
&lt;h2&gt;Procedure Steps&lt;/h2&gt;
&lt;ol&gt;
  &lt;li&gt;Step 1&lt;/li&gt;
  &lt;li&gt;Step 2&lt;/li&gt;
  &lt;li&gt;Step 3&lt;/li&gt;
&lt;/ol&gt;
&lt;h2&gt;Responsibilities&lt;/h2&gt;
&lt;p&gt;List roles and responsibilities.&lt;/p&gt;</field>
    </record>

    <record id="template_meeting_minutes" model="lekha.document.template">
        <field name="name">Meeting Minutes</field>
        <field name="document_type">report</field>
        <field name="category_id" ref="document_category_general"/>
        <field name="sequence">20</field>
        <field name="description">Template for recording meeting minutes and action items.</field>
        <field name="content">&lt;h2&gt;Meeting Details&lt;/h2&gt;
&lt;p&gt;&lt;strong&gt;Date:&lt;/strong&gt; [Date]&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Attendees:&lt;/strong&gt; [Names]&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Facilitator:&lt;/strong&gt; [Name]&lt;/p&gt;
&lt;h2&gt;Agenda Items&lt;/h2&gt;
&lt;ol&gt;&lt;li&gt;Item 1&lt;/li&gt;&lt;/ol&gt;
&lt;h2&gt;Decisions Made&lt;/h2&gt;
&lt;ul&gt;&lt;li&gt;Decision 1&lt;/li&gt;&lt;/ul&gt;
&lt;h2&gt;Action Items&lt;/h2&gt;
&lt;table border="1"&gt;
  &lt;tr&gt;&lt;th&gt;Action&lt;/th&gt;&lt;th&gt;Owner&lt;/th&gt;&lt;th&gt;Due Date&lt;/th&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;</field>
    </record>

    <record id="template_hr_policy" model="lekha.document.template">
        <field name="name">HR Policy Document</field>
        <field name="document_type">policy</field>
        <field name="category_id" ref="document_category_hr"/>
        <field name="sequence">30</field>
        <field name="description">Template for drafting HR policies.</field>
        <field name="content">&lt;h2&gt;Policy Statement&lt;/h2&gt;
&lt;p&gt;State the policy in clear terms.&lt;/p&gt;
&lt;h2&gt;Applicability&lt;/h2&gt;
&lt;p&gt;Who this policy applies to.&lt;/p&gt;
&lt;h2&gt;Policy Details&lt;/h2&gt;
&lt;p&gt;Detailed policy content.&lt;/p&gt;
&lt;h2&gt;Non-Compliance&lt;/h2&gt;
&lt;p&gt;Consequences of non-compliance.&lt;/p&gt;
&lt;h2&gt;Review Schedule&lt;/h2&gt;
&lt;p&gt;This policy will be reviewed annually.&lt;/p&gt;</field>
    </record>

    <!-- Sequences -->
    <record id="seq_lekha_document" model="ir.sequence">
        <field name="name">Document Sequence</field>
        <field name="code">lekha.document</field>
        <field name="prefix">DOC/%(year)s/</field>
        <field name="padding">5</field>
    </record>
    <record id="seq_lekha_policy" model="ir.sequence">
        <field name="name">Policy Sequence</field>
        <field name="code">lekha.company.policy</field>
        <field name="prefix">POL/%(year)s/</field>
        <field name="padding">4</field>
    </record>
</odoo>
