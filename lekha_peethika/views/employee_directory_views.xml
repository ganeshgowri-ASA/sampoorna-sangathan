<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Enhanced Employee Form -->
    <record id="lekha_hr_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.lekha</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Directory Profile" name="directory_profile">
                    <group>
                        <group string="Professional Info">
                            <field name="employee_type_display"/>
                            <field name="skills_text" placeholder="e.g. Python, Project Management, Data Analysis"/>
                            <field name="linkedin_url" widget="url"/>
                        </group>
                        <group string="About">
                            <field name="bio" placeholder="Short bio..."/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Employee Directory Kanban (enhanced) -->
    <record id="lekha_hr_employee_kanban_inherit" model="ir.ui.view">
        <field name="name">hr.employee.kanban.inherit.lekha</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
        <field name="arch" type="xml">
            <xpath expr="//templates" position="before">
                <field name="employee_type_display"/>
                <field name="skills_text"/>
            </xpath>
        </field>
    </record>

    <!-- Employee Directory List View -->
    <record id="lekha_hr_employee_list_directory" model="ir.ui.view">
        <field name="name">hr.employee.list.directory.lekha</field>
        <field name="model">hr.employee</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <tree string="Employee Directory">
                <field name="name"/>
                <field name="job_title"/>
                <field name="department_id"/>
                <field name="work_email"/>
                <field name="work_phone"/>
                <field name="employee_type_display"/>
                <field name="parent_id" string="Manager"/>
            </tree>
        </field>
    </record>

    <record id="action_lekha_employee_directory" model="ir.actions.act_window">
        <field name="name">Employee Directory</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('hr.hr_kanban_view_employees')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('lekha_hr_employee_list_directory')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr.view_employee_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No employees found</p>
            <p>Browse and search the employee directory.</p>
        </field>
    </record>
</odoo>
