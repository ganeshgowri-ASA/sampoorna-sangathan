<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="lekha_policy_list" model="ir.ui.view">
        <field name="name">lekha.company.policy.list</field>
        <field name="model">lekha.company.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="reference"/>
                <field name="name"/>
                <field name="category"/>
                <field name="version"/>
                <field name="effective_date"/>
                <field name="review_date"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'review'" decoration-success="state == 'active'" decoration-muted="state == 'superseded'"/>
            </tree>
        </field>
    </record>

    <record id="lekha_policy_form" model="ir.ui.view">
        <field name="name">lekha.company.policy.form</field>
        <field name="model">lekha.company.policy</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'review'" groups="hr.group_hr_manager"/>
                    <button name="action_supersede" string="Supersede" type="object" invisible="state != 'active'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Policy Title"/></h1>
                        <field name="reference"/>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="version"/>
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="approved_by_id" widget="many2one_avatar_user" readonly="1"/>
                        </group>
                        <group>
                            <field name="effective_date"/>
                            <field name="review_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Policy Content" name="content">
                            <field name="summary" placeholder="Brief summary of the policy..."/>
                            <separator string="Full Policy"/>
                            <field name="content"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="lekha_policy_search" model="ir.ui.view">
        <field name="name">lekha.company.policy.search</field>
        <field name="model">lekha.company.policy</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="reference"/>
                <field name="category"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Active Policies" name="active_policies" domain="[('state', '=', 'active')]"/>
                <filter string="Under Review" name="review" domain="[('state', '=', 'review')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lekha_policy" model="ir.actions.act_window">
        <field name="name">Company Policies</field>
        <field name="res_model">lekha.company.policy</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="lekha_policy_search"/>
        <field name="context">{'search_default_active_policies': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first company policy</p>
            <p>Manage and publish company policies for all employees.</p>
        </field>
    </record>
</odoo>
