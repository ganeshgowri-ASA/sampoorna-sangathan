<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Deliverable Tree View -->
    <record id="view_deliverable_tree" model="ir.ui.view">
        <field name="name">project.deliverable.tree</field>
        <field name="model">project.deliverable</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="milestone_id"/>
                <field name="project_id"/>
                <field name="assigned_to"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="priority"/>
            </tree>
        </field>
    </record>

    <!-- Deliverable Form View -->
    <record id="view_deliverable_form" model="ir.ui.view">
        <field name="name">project.deliverable.form</field>
        <field name="model">project.deliverable</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Start" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_review" string="Submit for Review" type="object"
                            class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            class="btn-success"
                            invisible="state != 'review'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="milestone_id"/>
                            <field name="project_id"/>
                            <field name="assigned_to"/>
                        </group>
                        <group>
                            <field name="due_date"/>
                            <field name="completion_date"/>
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Deliverable Action -->
    <record id="action_project_deliverable" model="ir.actions.act_window">
        <field name="name">Deliverables</field>
        <field name="res_model">project.deliverable</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a deliverable
            </p>
        </field>
    </record>
</odoo>
