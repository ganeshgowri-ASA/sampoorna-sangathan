<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Project Form -->
    <record id="view_project_form_inherit" model="ir.ui.view">
        <field name="name">project.project.form.inherit.pariyojana</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sprints" type="object"
                        class="oe_stat_button" icon="fa-bolt">
                    <field name="sprint_count" widget="statinfo" string="Sprints"/>
                </button>
                <button name="action_view_allocations" type="object"
                        class="oe_stat_button" icon="fa-users">
                    <span class="o_stat_text">Allocations</span>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
