<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sprint Kanban View -->
    <record id="view_sprint_kanban" model="ir.ui.view">
        <field name="name">project.sprint.kanban</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field name="stage_id"/>
                <field name="color"/>
                <field name="task_count"/>
                <field name="progress"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''} oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="project_id"/>
                                    <div class="mt4">
                                        <span><field name="date_start"/> - <field name="date_end"/></span>
                                    </div>
                                    <div class="mt4">
                                        Tasks: <field name="task_count"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="progress" widget="progressbar"
                                               options="{'current_value': 'progress', 'max_value': 100}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Sprint Tree View -->
    <record id="view_sprint_tree" model="ir.ui.view">
        <field name="name">project.sprint.tree</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="stage_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="velocity"/>
                <field name="actual_hours"/>
                <field name="task_count"/>
                <field name="progress" widget="progressbar"/>
            </tree>
        </field>
    </record>

    <!-- Sprint Form View -->
    <record id="view_sprint_form" model="ir.ui.view">
        <field name="name">project.sprint.form</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage_id" widget="statusbar" clickable="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Sprint Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="velocity"/>
                            <field name="actual_hours"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sprint Goal">
                            <field name="goal"/>
                        </page>
                        <page string="Tasks">
                            <field name="task_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="stage_id"/>
                                    <field name="allocated_hours"/>
                                    <field name="effective_hours"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Sprint Action -->
    <record id="action_project_sprint" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">project.sprint</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sprint
            </p>
            <p>Plan and track your project sprints with kanban boards.</p>
        </field>
    </record>
</odoo>
