<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template Tree -->
    <record id="view_template_tree" model="ir.ui.view">
        <field name="name">project.template.tree</field>
        <field name="model">project.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="default_sprint_duration"/>
            </tree>
        </field>
    </record>

    <!-- Template Form -->
    <record id="view_template_form" model="ir.ui.view">
        <field name="name">project.template.form</field>
        <field name="model">project.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_project" string="Create Project"
                                type="object" class="oe_stat_button" icon="fa-plus"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="default_sprint_duration"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Tasks">
                            <field name="task_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="planned_hours"/>
                                    <field name="tag_ids" widget="many2many_tags"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Default Milestones">
                            <field name="milestone_names"
                                   placeholder="One milestone per line..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Template Action -->
    <record id="action_project_template" model="ir.actions.act_window">
        <field name="name">Project Templates</field>
        <field name="res_model">project.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a project template
            </p>
            <p>Templates let you quickly set up new projects with predefined tasks and milestones.</p>
        </field>
    </record>
</odoo>
