<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Milestone Form Extension -->
    <record id="view_milestone_form_inherit" model="ir.ui.view">
        <field name="name">project.milestone.form.inherit.pariyojana</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Tracking">
                    <group>
                        <field name="target_date"/>
                        <field name="completion_date"/>
                    </group>
                    <group>
                        <field name="status"/>
                        <field name="progress" widget="progressbar"/>
                        <field name="deliverable_count"/>
                    </group>
                </group>
                <notebook>
                    <page string="Deliverables">
                        <field name="deliverable_ids">
                            <tree editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="assigned_to"/>
                                <field name="due_date"/>
                                <field name="state"/>
                                <field name="priority"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
