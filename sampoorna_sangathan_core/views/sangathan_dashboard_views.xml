<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Action -->
    <record id="action_sangathan_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">sangathan.org.profile</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <div class="sangathan-welcome">
                <h2>Welcome to SampoornaSangathan</h2>
                <p>Your Unified Organisation Operating System</p>
                <p>Create an Organisation Profile to get started.</p>
            </div>
        </field>
    </record>

    <!-- Kanban View for Dashboard Tiles -->
    <record id="view_org_profile_kanban" model="ir.ui.view">
        <field name="name">sangathan.org.profile.kanban</field>
        <field name="model">sangathan.org.profile</field>
        <field name="arch" type="xml">
            <kanban class="o_sangathan_kanban" sample="1">
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="logo"/>
                <field name="module_hrms"/>
                <field name="module_crm"/>
                <field name="module_finance"/>
                <field name="module_inventory"/>
                <field name="module_projects"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_sangathan_tile">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('sangathan.org.profile', 'logo', record.id.raw_value)"
                                     alt="Logo" class="o_image_64_contain"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="code"/>
                                </div>
                                <div class="o_sangathan_modules mt-2">
                                    <span t-if="record.module_hrms.raw_value"
                                          class="badge rounded-pill text-bg-info me-1">HRMS</span>
                                    <span t-if="record.module_crm.raw_value"
                                          class="badge rounded-pill text-bg-success me-1">CRM</span>
                                    <span t-if="record.module_finance.raw_value"
                                          class="badge rounded-pill text-bg-warning me-1">Finance</span>
                                    <span t-if="record.module_inventory.raw_value"
                                          class="badge rounded-pill text-bg-primary me-1">Inventory</span>
                                    <span t-if="record.module_projects.raw_value"
                                          class="badge rounded-pill text-bg-secondary me-1">Projects</span>
                                </div>
                                <div class="mt-1">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'default', 'active': 'success', 'suspended': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tags Tree View -->
    <record id="view_sangathan_tag_tree" model="ir.ui.view">
        <field name="name">sangathan.tag.tree</field>
        <field name="model">sangathan.tag</field>
        <field name="arch" type="xml">
            <tree string="Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="module_scope"/>
            </tree>
        </field>
    </record>

    <!-- Tags Action -->
    <record id="action_sangathan_tags" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">sangathan.tag</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>
