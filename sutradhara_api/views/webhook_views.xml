<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Webhook List View -->
    <record id="sutradhara_webhook_view_list" model="ir.ui.view">
        <field name="name">sutradhara.webhook.list</field>
        <field name="model">sutradhara.webhook</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="url"/>
                <field name="model_name"/>
                <field name="trigger_on_create"/>
                <field name="trigger_on_write"/>
                <field name="trigger_on_unlink"/>
                <field name="last_triggered"/>
                <field name="last_status_code"
                       decoration-success="last_status_code &gt;= 200 and last_status_code &lt; 300"
                       decoration-danger="last_status_code &gt;= 400 or last_status_code == 0"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Webhook Form View -->
    <record id="sutradhara_webhook_view_form" model="ir.ui.view">
        <field name="name">sutradhara.webhook.form</field>
        <field name="model">sutradhara.webhook</field>
        <field name="arch" type="xml">
            <form string="Webhook">
                <header>
                    <button name="action_test_webhook" type="object"
                            string="Test Webhook" class="btn-primary"/>
                    <button name="action_regenerate_secret" type="object"
                            string="Regenerate Secret" class="btn-warning"
                            confirm="This will change the signing secret. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Webhook Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="url" widget="url"/>
                            <field name="model_id"/>
                            <field name="secret" password="True"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="trigger_on_create"/>
                            <field name="trigger_on_write"/>
                            <field name="trigger_on_unlink"/>
                            <field name="last_triggered"/>
                            <field name="last_status_code"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Custom Headers">
                            <field name="headers"
                                   placeholder='{"X-Custom-Header": "value"}'/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Webhook Action -->
    <record id="sutradhara_webhook_action" model="ir.actions.act_window">
        <field name="name">Webhooks</field>
        <field name="res_model">sutradhara.webhook</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your first webhook
            </p>
            <p>
                Webhooks notify external services when data changes in Odoo.
            </p>
        </field>
    </record>
</odoo>
