<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Log List View -->
    <record id="sutradhara_api_log_view_list" model="ir.ui.view">
        <field name="name">sutradhara.api.log.list</field>
        <field name="model">sutradhara.api.log</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0"
                  decoration-danger="response_code &gt;= 400"
                  decoration-warning="response_code &gt;= 300 and response_code &lt; 400"
                  decoration-success="response_code &gt;= 200 and response_code &lt; 300">
                <field name="timestamp"/>
                <field name="endpoint"/>
                <field name="method"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="api_key_id"/>
                <field name="ip_address"/>
                <field name="response_code"/>
                <field name="response_time_ms"/>
                <field name="error_message"/>
            </tree>
        </field>
    </record>

    <!-- API Log Search View -->
    <record id="sutradhara_api_log_view_search" model="ir.ui.view">
        <field name="name">sutradhara.api.log.search</field>
        <field name="model">sutradhara.api.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="endpoint"/>
                <field name="user_id"/>
                <field name="api_key_id"/>
                <field name="ip_address"/>
                <filter string="Errors" name="errors" domain="[('response_code', '&gt;=', 400)]"/>
                <filter string="Today" name="today" domain="[('timestamp', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Endpoint" name="group_endpoint" context="{'group_by': 'endpoint'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="API Key" name="group_key" context="{'group_by': 'api_key_id'}"/>
                    <filter string="Method" name="group_method" context="{'group_by': 'method'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- API Log Action -->
    <record id="sutradhara_api_log_action" model="ir.actions.act_window">
        <field name="name">API Logs</field>
        <field name="res_model">sutradhara.api.log</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>
</odoo>
