<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Invoice Analytics Tree View -->
    <record id="view_invoice_analytics_tree" model="ir.ui.view">
        <field name="name">kosha.invoice.analytics.tree</field>
        <field name="model">kosha.invoice.analytics</field>
        <field name="arch" type="xml">
            <tree string="Invoice Analytics" create="0" edit="0" delete="0">
                <field name="move_id"/>
                <field name="partner_id"/>
                <field name="invoice_date"/>
                <field name="due_date"/>
                <field name="move_type"/>
                <field name="amount_total" sum="Total"/>
                <field name="amount_residual" sum="Total Due"/>
                <field name="amount_paid" sum="Total Paid"/>
                <field name="days_overdue" decoration-danger="days_overdue > 0"/>
                <field name="aging_bucket" widget="badge"
                       decoration-success="aging_bucket == 'Paid'"
                       decoration-info="aging_bucket == 'Current'"
                       decoration-warning="aging_bucket == '1-30 Days'"
                       decoration-danger="aging_bucket in ('61-90 Days', '90+ Days')"/>
            </tree>
        </field>
    </record>

    <!-- Invoice Analytics Pivot View -->
    <record id="view_invoice_analytics_pivot" model="ir.ui.view">
        <field name="name">kosha.invoice.analytics.pivot</field>
        <field name="model">kosha.invoice.analytics</field>
        <field name="arch" type="xml">
            <pivot string="Invoice Analytics">
                <field name="aging_bucket" type="row"/>
                <field name="move_type" type="col"/>
                <field name="amount_total" type="measure"/>
                <field name="amount_residual" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Invoice Analytics Graph View -->
    <record id="view_invoice_analytics_graph" model="ir.ui.view">
        <field name="name">kosha.invoice.analytics.graph</field>
        <field name="model">kosha.invoice.analytics</field>
        <field name="arch" type="xml">
            <graph string="Invoice Analytics" type="bar">
                <field name="month"/>
                <field name="amount_total" type="measure"/>
                <field name="amount_residual" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Invoice Analytics Search View -->
    <record id="view_invoice_analytics_search" model="ir.ui.view">
        <field name="name">kosha.invoice.analytics.search</field>
        <field name="model">kosha.invoice.analytics</field>
        <field name="arch" type="xml">
            <search string="Invoice Analytics">
                <field name="partner_id"/>
                <field name="move_type"/>
                <field name="aging_bucket"/>
                <filter name="customer_invoices" string="Customer Invoices"
                        domain="[('move_type', '=', 'out_invoice')]"/>
                <filter name="vendor_bills" string="Vendor Bills"
                        domain="[('move_type', '=', 'in_invoice')]"/>
                <filter name="overdue" string="Overdue"
                        domain="[('days_overdue', '>', 0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_aging" string="Aging Bucket" context="{'group_by': 'aging_bucket'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'move_type'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Invoice Analytics Action -->
    <record id="action_invoice_analytics" model="ir.actions.act_window">
        <field name="name">Invoice Analytics</field>
        <field name="res_model">kosha.invoice.analytics</field>
        <field name="view_mode">pivot,graph,tree</field>
    </record>

</odoo>
