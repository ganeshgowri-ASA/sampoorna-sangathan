<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_new" model="kosha.expense.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
        </record>
        <record id="stage_review" model="kosha.expense.stage">
            <field name="name">Under Review</field>
            <field name="sequence">20</field>
        </record>
        <record id="stage_approved" model="kosha.expense.stage">
            <field name="name">Approved</field>
            <field name="sequence">30</field>
            <field name="is_approved" eval="True"/>
        </record>
        <record id="stage_paid" model="kosha.expense.stage">
            <field name="name">Paid</field>
            <field name="sequence">40</field>
            <field name="fold" eval="True"/>
        </record>
        <record id="stage_rejected" model="kosha.expense.stage">
            <field name="name">Rejected</field>
            <field name="sequence">50</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>
