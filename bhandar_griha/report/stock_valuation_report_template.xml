<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_stock_valuation_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Stock Valuation Report</h2>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Warehouse</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Unit Cost</th>
                                <th class="text-end">Total Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td><t t-esc="doc.product_id.display_name"/></td>
                                    <td><t t-esc="doc.product_categ_id.display_name"/></td>
                                    <td><t t-esc="doc.warehouse_id.name"/></td>
                                    <td class="text-end"><t t-esc="doc.quantity"/></td>
                                    <td class="text-end"><t t-esc="doc.standard_price"/></td>
                                    <td class="text-end"><t t-esc="doc.total_value"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
