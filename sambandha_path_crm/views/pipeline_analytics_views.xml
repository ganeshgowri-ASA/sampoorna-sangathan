<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pipeline Analytics: Tree View -->
    <record id="view_pipeline_analytics_tree" model="ir.ui.view">
        <field name="name">sambandha.pipeline.analytics.tree</field>
        <field name="model">sambandha.pipeline.analytics</field>
        <field name="arch" type="xml">
            <tree decoration-success="is_won" decoration-danger="is_lost" create="0" edit="0">
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="team_id"/>
                <field name="stage_id"/>
                <field name="lead_type"/>
                <field name="expected_revenue" sum="Total Expected"/>
                <field name="probability"/>
                <field name="weighted_revenue" sum="Total Weighted"/>
                <field name="sp_lead_score"/>
                <field name="days_in_stage"/>
                <field name="days_to_close" optional="show"/>
                <field name="is_won" column_invisible="1"/>
                <field name="is_lost" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Pipeline Analytics: Pivot View -->
    <record id="view_pipeline_analytics_pivot" model="ir.ui.view">
        <field name="name">sambandha.pipeline.analytics.pivot</field>
        <field name="model">sambandha.pipeline.analytics</field>
        <field name="arch" type="xml">
            <pivot string="Pipeline Analytics">
                <field name="stage_id" type="row"/>
                <field name="team_id" type="col"/>
                <field name="expected_revenue" type="measure"/>
                <field name="weighted_revenue" type="measure"/>
                <field name="sp_lead_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Pipeline Analytics: Graph View -->
    <record id="view_pipeline_analytics_graph" model="ir.ui.view">
        <field name="name">sambandha.pipeline.analytics.graph</field>
        <field name="model">sambandha.pipeline.analytics</field>
        <field name="arch" type="xml">
            <graph string="Pipeline Analytics" type="bar">
                <field name="stage_id"/>
                <field name="weighted_revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pipeline Analytics: Search View -->
    <record id="view_pipeline_analytics_search" model="ir.ui.view">
        <field name="name">sambandha.pipeline.analytics.search</field>
        <field name="model">sambandha.pipeline.analytics</field>
        <field name="arch" type="xml">
            <search string="Pipeline Analytics">
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <filter name="leads_only" string="Leads" domain="[('lead_type', '=', 'lead')]"/>
                <filter name="opps_only" string="Opportunities" domain="[('lead_type', '=', 'opportunity')]"/>
                <separator/>
                <filter name="won" string="Won" domain="[('is_won', '=', True)]"/>
                <filter name="lost" string="Lost" domain="[('is_lost', '=', True)]"/>
                <separator/>
                <filter name="high_score" string="High Score (50+)" domain="[('sp_lead_score', '>=', 50)]"/>
                <separator/>
                <filter name="group_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                <filter name="group_team" string="Sales Team" context="{'group_by': 'team_id'}"/>
                <filter name="group_user" string="Salesperson" context="{'group_by': 'user_id'}"/>
                <filter name="group_month" string="Month" context="{'group_by': 'create_month'}"/>
                <filter name="group_country" string="Country" context="{'group_by': 'country_id'}"/>
            </search>
        </field>
    </record>

    <!-- Pipeline Analytics: Action -->
    <record id="action_pipeline_analytics" model="ir.actions.act_window">
        <field name="name">Pipeline Analytics</field>
        <field name="res_model">sambandha.pipeline.analytics</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pipeline data available
            </p>
            <p>Pipeline analytics provides insights into your sales funnel, conversion rates, and revenue forecasting.</p>
        </field>
    </record>
</odoo>
