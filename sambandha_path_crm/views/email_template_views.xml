<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Email Template Library: Tree View -->
    <record id="view_crm_email_template_tree" model="ir.ui.view">
        <field name="name">sambandha.email.template.tree</field>
        <field name="model">sambandha.email.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category" widget="badge"/>
                <field name="subject"/>
                <field name="stage_id"/>
                <field name="usage_count"/>
            </tree>
        </field>
    </record>

    <!-- Email Template Library: Form View -->
    <record id="view_crm_email_template_form" model="ir.ui.view">
        <field name="name">sambandha.email.template.form</field>
        <field name="model">sambandha.email.template</field>
        <field name="arch" type="xml">
            <form string="Email Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="stage_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="usage_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Email Body" name="body">
                            <field name="body_html" nolabel="1"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1" placeholder="Internal notes about when to use this template..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Email Template Library: Search View -->
    <record id="view_crm_email_template_search" model="ir.ui.view">
        <field name="name">sambandha.email.template.search</field>
        <field name="model">sambandha.email.template</field>
        <field name="arch" type="xml">
            <search string="Email Templates">
                <field name="name"/>
                <field name="subject"/>
                <filter name="introduction" string="Introduction" domain="[('category', '=', 'introduction')]"/>
                <filter name="followup" string="Follow-up" domain="[('category', '=', 'followup')]"/>
                <filter name="proposal" string="Proposal" domain="[('category', '=', 'proposal')]"/>
                <filter name="closing" string="Closing" domain="[('category', '=', 'closing')]"/>
                <separator/>
                <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                <filter name="group_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
            </search>
        </field>
    </record>

    <!-- Email Template Library: Action -->
    <record id="action_crm_email_templates" model="ir.actions.act_window">
        <field name="name">Email Templates</field>
        <field name="res_model">sambandha.email.template</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first email template
            </p>
            <p>Build a library of reusable email templates for different stages of your sales process.</p>
        </field>
    </record>
</odoo>
