<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit CRM Lead Form: Add scoring and follow-up fields -->
    <record id="view_crm_lead_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.sambandha</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add scoring button in header -->
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <div class="oe_button_box" name="sp_button_box">
                    <button name="action_view_sale_orders" type="object"
                            class="oe_stat_button" icon="fa-shopping-cart"
                            invisible="not partner_id">
                        <field name="sp_sale_order_count" widget="statinfo" string="Sales Orders"/>
                    </button>
                </div>
            </xpath>

            <!-- Add Lead Score badge near title -->
            <xpath expr="//div[hasclass('oe_title')]" position="inside">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <field name="sp_lead_score" widget="progressbar" options="{'max_value': 100}"/>
                    <field name="sp_score_grade" widget="badge"
                           decoration-danger="sp_score_grade == 'cold'"
                           decoration-warning="sp_score_grade == 'warm'"
                           decoration-success="sp_score_grade == 'hot'"
                           decoration-info="sp_score_grade == 'on_fire'"/>
                </div>
            </xpath>

            <!-- Add Scoring & Follow-up tab -->
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Lead Scoring" name="sp_scoring">
                    <group>
                        <group string="Combined Score">
                            <field name="sp_lead_score"/>
                            <field name="sp_score_grade"/>
                            <button name="action_compute_lead_score" type="object"
                                    string="Recompute Score" class="btn-secondary"/>
                        </group>
                        <group string="Activity Score (AI)">
                            <field name="sp_activity_score" widget="progressbar"
                                   options="{'max_value': 100}"/>
                            <field name="sp_email_count"/>
                            <field name="sp_meeting_count"/>
                            <field name="sp_message_count"/>
                            <field name="sp_activity_recency_days"/>
                        </group>
                    </group>
                    <group string="Score Breakdown">
                        <field name="sp_score_details" nolabel="1"/>
                    </group>
                </page>
                <page string="Follow-up" name="sp_followup">
                    <group>
                        <group string="Follow-up Tracking">
                            <field name="sp_last_followup_date"/>
                            <field name="sp_next_followup_date"/>
                            <field name="sp_followup_count"/>
                            <field name="sp_days_since_last_contact"/>
                            <field name="sp_followup_status" widget="badge"
                                   decoration-success="sp_followup_status == 'on_track'"
                                   decoration-warning="sp_followup_status == 'due'"
                                   decoration-danger="sp_followup_status == 'overdue'"/>
                            <button name="action_log_followup" type="object"
                                    string="Log Follow-up" class="btn-primary"/>
                        </group>
                        <group string="Customer Revenue">
                            <field name="sp_total_revenue"/>
                            <field name="sp_sale_order_count"/>
                        </group>
                    </group>
                    <group string="Interaction Summary">
                        <field name="sp_interaction_summary" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Inherit CRM Lead Tree: Add score column -->
    <record id="view_crm_lead_tree_inherit" model="ir.ui.view">
        <field name="name">crm.lead.tree.inherit.sambandha</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="before">
                <field name="sp_lead_score" string="Score"/>
                <field name="sp_score_grade" widget="badge"
                       decoration-danger="sp_score_grade == 'cold'"
                       decoration-warning="sp_score_grade == 'warm'"
                       decoration-success="sp_score_grade == 'hot'"
                       decoration-info="sp_score_grade == 'on_fire'"/>
                <field name="sp_followup_status" widget="badge"
                       decoration-success="sp_followup_status == 'on_track'"
                       decoration-warning="sp_followup_status == 'due'"
                       decoration-danger="sp_followup_status == 'overdue'"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit CRM Lead Search: Add scoring filters -->
    <record id="view_crm_lead_search_inherit" model="ir.ui.view">
        <field name="name">crm.lead.search.inherit.sambandha</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter name="sp_hot_leads" string="Hot Leads" domain="[('sp_score_grade', 'in', ['hot', 'on_fire'])]"/>
                <filter name="sp_cold_leads" string="Cold Leads" domain="[('sp_score_grade', '=', 'cold')]"/>
                <filter name="sp_overdue_followup" string="Overdue Follow-up"
                        domain="[('sp_next_followup_date', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="sp_group_score_grade" string="Score Grade" context="{'group_by': 'sp_score_grade'}"/>
            </xpath>
        </field>
    </record>
</odoo>
