<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default Lead Scoring Rules -->
        <record id="scoring_rule_high_revenue" model="sambandha.lead.scoring.rule">
            <field name="name">High Expected Revenue</field>
            <field name="sequence">10</field>
            <field name="criteria_type">revenue</field>
            <field name="revenue_min">50000</field>
            <field name="revenue_max">0</field>
            <field name="score_points">30</field>
        </record>

        <record id="scoring_rule_medium_revenue" model="sambandha.lead.scoring.rule">
            <field name="name">Medium Expected Revenue</field>
            <field name="sequence">20</field>
            <field name="criteria_type">revenue</field>
            <field name="revenue_min">10000</field>
            <field name="revenue_max">49999</field>
            <field name="score_points">15</field>
        </record>

        <record id="scoring_rule_website_source" model="sambandha.lead.scoring.rule">
            <field name="name">Website Lead Source</field>
            <field name="sequence">30</field>
            <field name="criteria_type">source</field>
            <field name="source_id" ref="utm.utm_source_newsletter"/>
            <field name="score_points">10</field>
        </record>

        <record id="scoring_rule_corporate_email" model="sambandha.lead.scoring.rule">
            <field name="name">Corporate Email (not gmail/yahoo)</field>
            <field name="sequence">40</field>
            <field name="criteria_type">email_domain</field>
            <field name="field_value">.com</field>
            <field name="score_points">5</field>
        </record>
    </data>
</odoo>
