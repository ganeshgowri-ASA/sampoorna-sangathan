<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Dashboard Entries -->
        <record id="seq_bhandar_griha_dashboard" model="ir.sequence">
            <field name="name">Bhandar Griha Dashboard Sequence</field>
            <field name="code">bhandar.griha.dashboard</field>
            <field name="prefix">BG-DASH-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Replenishment Rules -->
        <record id="seq_bhandar_griha_replenishment" model="ir.sequence">
            <field name="name">Bhandar Griha Replenishment Sequence</field>
            <field name="code">bhandar.griha.replenishment</field>
            <field name="prefix">BG-RPL-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
